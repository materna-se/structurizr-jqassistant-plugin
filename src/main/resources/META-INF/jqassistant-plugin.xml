<jqassistant-plugin xmlns="http://schema.jqassistant.org/plugin/v2.4"
                    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                    xsi:schemaLocation="http://schema.jqassistant.org/plugin/v2.4 https://jqassistant.github.io/jqassistant/current/schema/jqassistant-plugin-v2.4.xsd"
                    name="Structurizr jQAssistant Plugin" id="jqa.plugin.structurizr"
                    version="${project.version}">
    <description>${project.description}</description>
    <model>
        <class>de.materna.structurizr.jqassistant.plugin.model.ComponentDescriptor</class>
        <class>de.materna.structurizr.jqassistant.plugin.model.ContainerDescriptor</class>
        <class>de.materna.structurizr.jqassistant.plugin.model.ElementDescriptor</class>
        <class>de.materna.structurizr.jqassistant.plugin.model.ModelDescriptor</class>
        <class>de.materna.structurizr.jqassistant.plugin.model.PersonDescriptor</class>
        <class>de.materna.structurizr.jqassistant.plugin.model.StructurizrDescriptor</class>
        <class>de.materna.structurizr.jqassistant.plugin.model.StructurizrFileDescriptor</class>
        <class>de.materna.structurizr.jqassistant.plugin.model.SystemDescriptor</class>
        <class>de.materna.structurizr.jqassistant.plugin.model.WorkspaceDescriptor</class>
    </model>
    <scanner>
        <class>de.materna.structurizr.jqassistant.plugin.StructurizrWorkspaceScannerPlugin</class>
    </scanner>
</jqassistant-plugin>